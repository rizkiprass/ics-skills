# AWS Technical Document Generator - Configuration File
# Copy file ini menjadi .env dan isi dengan nilai yang sesuai

# ============================================
# AWS CREDENTIALS
# ============================================
# PENTING: Gunakan credentials dengan READ-ONLY permission saja!
# Jangan commit file .env ke Git repository!

AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=ap-southeast-1

# ============================================
# PROJECT INFORMATION
# ============================================
# Informasi project yang akan muncul di document

PROJECT_NAME=SAP HANA Migration
CUSTOMER_NAME=PT Telkom Indonesia

# ============================================
# DOCUMENT SETTINGS
# ============================================
# Versi document (contoh: 1.0, 1.1, 2.0)

DOCUMENT_VERSION=1.0

# ============================================
# OPTIONAL SETTINGS
# ============================================
# Uncomment jika ingin menggunakan

# OUTPUT_FORMAT=markdown
# INCLUDE_COST_ANALYSIS=false
# SCAN_TIMEOUT=300
